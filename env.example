# Supabase (used for auth and, when MySQL API is off, for data)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Optional: use MySQL backend for all data (auth stays Supabase)
# Set to true to call the Node/MySQL API instead of Supabase for CRM data
VITE_USE_MYSQL_API=false
VITE_API_URL=http://localhost:3001

# Server (when running npm run server) - create server/.env or set in shell
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=crm
# SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard
# PORT=3001
